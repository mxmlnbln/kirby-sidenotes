{
  "name": "mxmlnbln/kirby-sidenotes",
  "description": "Tufte-style sidenotes for Kirby — footnotes in the page margin, as a KirbyText tag",
  "type": "kirby-plugin",
  "license": "MIT",
  "version": "1.0.0",
  "keywords": ["kirby", "kirby-cms", "kirby-plugin", "footnotes", "sidenotes", "tufte"],
  "homepage": "https://github.com/mxmlnbln/kirby-sidenotes",
  "authors": [
    {
      "name": "mxmlnbln"
    }
  ],
  "require": {
    "php": ">=8.1",
    "getkirby/composer-installer": "^1.2"
  },
  "extra": {
    "installer-name": "sidenotes",
    "kirby-cms-path": false
  }
}
